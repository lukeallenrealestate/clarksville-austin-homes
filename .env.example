# Copy to .env.local and fill in. None are required to run with sample data.

# Production domain, no trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.clarksvilleaustinhomes.com

# Google Analytics 4 Measurement ID, format G-XXXXXXXXXX.
NEXT_PUBLIC_GA4_ID=

# MLS Grid (Unlock MLS / ACTRIS) access token. Used by `npm run sync:listings`
# to pull live Clarksville (78703) listings into src/data/clarksville-listings.json.
MLS_GRID_TOKEN=

# Lead delivery by email (Gmail SMTP). Requires 2-Step Verification on the
# Google account, then an App Password (Google Account > Security > App
# passwords). Put the 16 characters with spaces removed.
GMAIL_USER=luke@austinmdg.com
GMAIL_APP_PASSWORD=
LEAD_TO=luke@austinmdg.com

# Optional extra fan-out (Zapier/Make/CRM webhook). Leave blank if unused.
LEAD_WEBHOOK_URL=
